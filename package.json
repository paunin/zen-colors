{
  "name": "fluid-colors",
  "version": "1.0.0",
  "description": "A comprehensive React component for rendering animated fluid color gradients with Canvas 2D",
  "type": "module",
  "main": "./dist/fluid-colors.umd.cjs",
  "module": "./dist/fluid-colors.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/fluid-colors.js",
      "require": "./dist/fluid-colors.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.0"
  },
  "keywords": [
    "react",
    "fluid",
    "colors",
    "gradient",
    "animation",
    "canvas",
    "blob",
    "background"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/fluid-colors"
  }
}
